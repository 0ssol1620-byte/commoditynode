    {
      "id": "repo-timesfm-forecast-artifact",
      "type": "command",
      "severity": "medium",
      "command": "python3 - <<'PY'\nimport json\nfrom pathlib import Path\nobj = json.loads(Path('assets/data/forecast.json').read_text())\nrequired = ['crude_oil', 'gold', 'natural_gas', 'copper']\nmissing = []\nfor key in required:\n    tf = obj.get(key, {}).get('timesfm_forecast')\n    if not tf or len(tf.get('median', [])) != 90 or len(tf.get('p10', [])) != 90 or len(tf.get('p90', [])) != 90:\n        missing.append(key)\nif missing:\n    raise SystemExit('Missing or invalid timesfm_forecast for: ' + ', '.join(missing))\nprint('timesfm_forecast OK for', ', '.join(required))\nPY"
    }
